{
    "compilerOptions": {
        "strict": true,
        "module": "esnext",
        "target": "esnext",
        "declaration": false,
        "noEmitOnError": true,
        "sourceMap": false,
        "rootDir": "..",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "types": ["react", "react-dom", "node"]
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "../src/**/*.ts",
        "../src/**/*.tsx",
        "../src/**/*.d.ts"
    ],
    "exclude": [
        "node_modules",
        "src/experiments",
        "src/experiments-new",
    ]
}